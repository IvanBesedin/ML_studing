# ─────────────────────────────────────
# DVC
# ─────────────────────────────────────
.dvc/cache/
.dvc/tmp/
.dvc/lock

# ─────────────────────────────────────
# Данные (игнорируем файлы, но НЕ .dvc)
# ─────────────────────────────────────
data/raw/*.csv
data/raw/*.parquet
data/raw/*.json
!data/raw/*.csv.dvc
!data/raw/*.parquet.dvc
!data/raw/*.json.dvc

data/processed/*
!data/processed/*.dvc

# ─────────────────────────────────────
# Модели
# ─────────────────────────────────────
models/*.pkl
models/*.pth
models/*.h5
!models/*.dvc

# ─────────────────────────────────────
# Python
# ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
*.egg-info/
*.pyc
.pytest_cache/

# ─────────────────────────────────────
# Jupyter
# ─────────────────────────────────────
.ipynb_checkpoints/

# ─────────────────────────────────────
# IDE
# ─────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─────────────────────────────────────
# OS
# ─────────────────────────────────────
.DS_Store
Thumbs.db